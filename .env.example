# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Domain (no https://)
DOMAIN=yourdomain.com

# Subdomains for SWAG (comma-separated, leave empty if using root domain)
# e.g. SUBDOMAINS=lan  →  lan.yourdomain.com
SUBDOMAINS=

# Email for Let's Encrypt certificate registration
EMAIL=your@email.com

# Database
DB_NAME=netmanager
DB_USER=netmanager
DB_PASS=changeme_strong_password

# Admin user created on first boot
ADMIN_USER=admin
ADMIN_PASS=changeme_strong_password

# Long random string — used to sign PHP sessions
APP_SECRET=change-this-to-a-long-random-string

# Timezone
TZ=America/New_York
